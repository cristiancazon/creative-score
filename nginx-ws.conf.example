# Nginx WebSocket proxy configuration for Directus
# Add these directives to your score.xerex.tech server block
#
# The key addition is the /websocket location block that handles
# WebSocket upgrade headers for Directus realtime subscriptions.

# Main Directus API (existing config probably has this already)
location / {
    proxy_pass http://directus-score:8055;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    # WebSocket support - CRITICAL for realtime clock sync
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    
    # Increase timeouts for WebSocket connections
    proxy_read_timeout 86400s;
    proxy_send_timeout 86400s;
}

# If using nginx-proxy (docker-gen), you may need to add a custom
# location for /websocket specifically. Check your nginx-proxy config at:
# /etc/nginx/vhost.d/score.xerex.tech
#
# Create that file with the WebSocket headers:
# proxy_http_version 1.1;
# proxy_set_header Upgrade $http_upgrade;
# proxy_set_header Connection "upgrade";
# proxy_read_timeout 86400s;
# proxy_send_timeout 86400s;
